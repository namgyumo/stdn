---
import BaseLayout from '@layouts/BaseLayout.astro';
// BOJ 서비스 종료로 BojWidget 비활성화
// import BojWidget from '@components/BojWidget.astro';
import { getCollection } from 'astro:content';
import { formatShortDate } from '@lib/format';
// import { site } from '@lib/site'; // BOJ 링크 제거로 미사용

const posts = (
  await getCollection('blog', ({ data }) => !data.draft && data.tags.includes('ps'))
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout
  title="PS"
  description="std::N 의 알고리즘 풀이 모음. 코드포스·ICPC 문제 중심."
>
  <section class="container container-narrow" style="padding-top: 60px;">
    <header class="center" style="margin-bottom: 40px;">
      <p class="eyebrow">// problem solving</p>
      <h1 class="h1">Problem Solving</h1>
      <p style="color: var(--color-fg-dim); font-family: var(--font-mono); margin-top: 10px;">
        코드포스 · ICPC
      </p>
    </header>

    {/* <BojWidget /> — BOJ 서비스 종료로 비활성화 */}

    <div style="margin-top: 80px;">
      <h2 class="section-h1">Writeups</h2>
      {posts.length === 0 ? (
        <p style="text-align: center; color: var(--color-fg-dim); padding: 40px 0;">
          아직 <code>#ps</code> 태그가 붙은 글이 없습니다.
        </p>
      ) : (
        <ul class="post-list">
          {posts.map((p) => (
            <li>
              <a class="post-item" href={`/blog/${p.id}`}>
                <span class="post-date">{formatShortDate(p.data.publishedAt)}</span>
                <div>
                  <h3 class="post-title">{p.data.title}</h3>
                  {p.data.description && <p style="color: var(--color-fg-dim); font-size: .9rem; margin: 4px 0 0;">{p.data.description}</p>}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    {/* BOJ 서비스 종료로 solved.ac 프로필 링크 비활성화
    <p style="text-align: center; margin-top: 40px;">
      <a class="btntext" href={`https://solved.ac/${site.author.boj}`} target="_blank" rel="noopener noreferrer">
        → 전체 solved.ac 프로필
      </a>
    </p>
    */}
  </section>
</BaseLayout>
