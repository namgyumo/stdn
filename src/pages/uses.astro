---
import BaseLayout from '@layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Editor & Terminal',
    items: [
      ['주력 IDE', 'Visual Studio — C / C++ 네이티브 디버깅 주력'],
      ['보조 에디터', 'VSCode — 일반 편집·웹·마크다운'],
      ['셸 / OS', 'Ubuntu (WSL) — 리눅스 시스템 프로그래밍 연습'],
      ['폰트', 'JetBrains Mono — 리가처 활성화'],
      ['컬러 테마', 'Tokyo Night / GitHub Dark'],
    ],
  },
  {
    title: 'Languages & Tooling',
    items: [
      ['Primary', 'C — io/lib 만 쓰고 자료구조는 직접 구현'],
      ['Sub', 'C++ (설계 패턴) · Python · Java'],
      ['컴파일러', 'MSVC / gcc / clang'],
      ['빌드', 'Visual Studio 프로젝트 / Makefile'],
      ['VCS', 'Git + GitHub'],
    ],
  },
  {
    title: 'Hardware',
    items: [
      ['랩탑 (주력)', 'HP Victus 16'],
      ['CPU', 'AMD Ryzen 7 8845HS'],
      ['GPU', 'NVIDIA GeForce RTX 4060 Laptop'],
      ['RAM', '32GB'],
      ['Storage', '2TB NVMe'],
      ['OS', 'Windows 11 + WSL (Ubuntu)'],
    ],
  },
  {
    title: 'Web & DevOps',
    items: [
      ['배포', 'Cloudflare Pages + Pages Functions'],
      ['DNS / CDN', 'Cloudflare'],
      ['DB', 'Cloudflare D1 (SQLite at edge)'],
      ['AI', 'Google AI Studio · Gemini 2.0 Flash'],
      ['CI/CD', 'Git push → Cloudflare Pages 자동 배포'],
    ],
  },
  {
    title: 'Services',
    items: [
      // ['PS 플랫폼', 'BOJ · solved.ac'], // BOJ 서비스 종료로 비활성화
      ['작업 관리', 'Notion · Gmail'],
      ['음악', 'Spotify · YouTube Music'],
      ['영감', 'Namuwiki · GitHub Explore'],
    ],
  },
];
---

<BaseLayout
  title="Uses"
  description="std::N 이 쓰는 장비·에디터·도구 모음 — 자주 업데이트하는 setup 페이지."
>
  <section class="container container-narrow" style="padding-top: 80px;">
    <header class="center" style="margin-bottom: 40px;">
      <p class="eyebrow">// uses</p>
      <h1 class="h1">Uses</h1>
      <p style="color: var(--color-fg-dim); font-family: var(--font-mono); margin-top: 10px;">
        무엇으로 코드를 쓰고 있나
      </p>
    </header>

    {sections.map((sec) => (
      <section class="uses-section">
        <h2>{sec.title}</h2>
        <table class="uses-table">
          <tbody>
            {sec.items.map(([k, v]) => (
              <tr>
                <th scope="row">{k}</th>
                <td>{v}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    ))}

    <p class="ref">
      → <a href="https://uses.tech" target="_blank" rel="noopener noreferrer">uses.tech</a> 스타일 페이지입니다.
    </p>
  </section>
</BaseLayout>

<style>
  .uses-section {
    margin-top: 40px;
  }
  .uses-section h2 {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 3px;
    padding-bottom: 8px;
    border-bottom: 1px dashed rgba(193, 255, 0, 0.3);
    text-transform: uppercase;
    font-weight: 500;
  }
  .uses-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    margin-top: 14px;
  }
  .uses-table th {
    text-align: left;
    padding: 8px 14px 8px 0;
    color: var(--color-fg-dim);
    font-weight: 400;
    width: 140px;
    vertical-align: top;
  }
  .uses-table td {
    padding: 8px 0;
    color: var(--color-fg);
    vertical-align: top;
  }
  .ref {
    margin-top: 60px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-dim);
  }
  .ref a { color: var(--color-accent); }
</style>
