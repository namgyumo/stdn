---
import BaseLayout from '@layouts/BaseLayout.astro';
import { site } from '@lib/site';

const cards = [
  {
    icon: '[ GITHUB ]',
    label: 'Repositories & Commits',
    detail: 'github.com/namgyumo',
    href: site.author.github,
    external: true,
  },
  {
    icon: '[ GMAIL ]',
    label: 'Email & Business',
    detail: site.author.email,
    href: `mailto:${site.author.email}`,
    external: false,
  },
  {
    icon: '[ INSTAGRAM ]',
    label: 'Direct Message',
    detail: '@east_scale',
    href: site.author.instagram,
    external: true,
  },
  // BOJ 서비스 종료로 비활성화
  // {
  //   icon: '[ BOJ ]',
  //   label: 'Algorithm Profile',
  //   detail: `solved.ac/${site.author.boj}`,
  //   href: `https://solved.ac/${site.author.boj}`,
  //   external: true,
  // },
];
---

<BaseLayout
  title="Contact"
  description="std::N 과 연락하는 방법 — GitHub, Email, Instagram."
>
  <section class="contact-hero">
    <h1 class="h1">CONTACT</h1>
    <p class="h2">새로운 네트워킹과 기회를 환영합니다.</p>
  </section>

  <section class="container">
    <div class="contact-section">
      <div class="section-header">
        <h2 class="section-title">CONTACT_NETWORK</h2>
        <p class="terminal-text">Welcome to new networking and opportunities</p>
      </div>

      <div class="contact-grid">
        {cards.map((c) => (
          <a
            href={c.href}
            class="contact-card"
            target={c.external ? '_blank' : undefined}
            rel={c.external ? 'noopener noreferrer' : undefined}
          >
            <div class="contact-icon">{c.icon}</div>
            <div class="contact-label">{c.label}</div>
            <div class="contact-detail">{c.detail}</div>
          </a>
        ))}
      </div>

      <form class="contact-form" id="contact-form" name="contact" method="POST" action="/api/contact" novalidate>
        <h3 class="form-title">// send_message</h3>
        <label>
          <span>Your name</span>
          <input type="text" name="name" required autocomplete="name" maxlength="100" />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          <span>Message</span>
          <textarea name="message" rows="5" required minlength="5" maxlength="5000"></textarea>
        </label>
        <label class="hp" aria-hidden="true">
          <span>Website</span>
          <input type="text" name="website" tabindex="-1" autocomplete="off" />
        </label>
        <button type="submit" class="form-submit">TRANSMIT →</button>
        <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('contact-form');
      const status = document.getElementById('form-status');
      if (!form || !status) return;

      const ERR = {
        missing_fields: '이름·이메일·메시지를 모두 채워주세요.',
        invalid_email: '이메일 형식이 올바르지 않습니다.',
        message_too_short: '메시지가 너무 짧습니다 (5자 이상).',
        message_too_long: '메시지가 너무 깁니다 (5000자 이내).',
        name_too_long: '이름이 너무 깁니다 (100자 이내).',
        invalid_body: '요청을 해석할 수 없습니다.',
        send_failed: '메일 전송이 실패했습니다. 잠시 후 다시 시도해 주세요.',
        method_not_allowed: '잘못된 요청입니다.',
        network: '네트워크 오류. 연결을 확인하고 다시 시도해 주세요.',
      };

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('.form-submit');
        const data = new FormData(form);
        status.className = 'form-status';
        status.textContent = '전송 중...';
        if (btn) btn.setAttribute('disabled', 'true');

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify(Object.fromEntries(data)),
          });
          const j = await res.json().catch(() => ({}));
          if (j.ok) {
            status.className = 'form-status ok';
            status.textContent = j.mode === 'logged'
              ? '접수 완료 (메일 연결 전 — 로그로 기록됨).'
              : '메시지 전송 완료. 답장 드리겠습니다.';
            form.reset();
          } else {
            status.className = 'form-status err';
            status.textContent = ERR[j.error] ?? '전송 실패.';
          }
        } catch {
          status.className = 'form-status err';
          status.textContent = ERR.network;
        } finally {
          if (btn) btn.removeAttribute('disabled');
        }
      });
    })();
  </script>
</BaseLayout>

<style>
  .contact-hero {
    text-align: center;
    padding: 40px 20px 60px;
  }
  .contact-hero .h1 { display: inline-block; }
  .contact-form {
    margin-top: 80px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 640px;
    margin-inline: auto;
  }
  .form-title {
    font-family: var(--font-mono);
    color: var(--color-accent);
    letter-spacing: 2px;
    margin: 0 0 10px;
  }
  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-dim);
  }
  .contact-form input,
  .contact-form textarea {
    padding: 10px 14px;
    background: rgba(8, 8, 8, 0.8);
    border: 1px solid rgba(193, 255, 0, 0.25);
    border-radius: 6px;
    color: var(--color-fg);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    outline: none;
    transition: all var(--dur) var(--ease);
    resize: vertical;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 8px rgba(193, 255, 0, 0.3);
  }
  .form-submit {
    margin-top: 8px;
    padding: 12px 20px;
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    border-radius: 6px;
    font-family: var(--font-mono);
    letter-spacing: 3px;
    cursor: pointer;
    transition: all var(--dur) var(--ease);
  }
  .form-submit:hover {
    background: rgba(193, 255, 0, 0.1);
    box-shadow: var(--glow-lime);
  }
  .form-submit[disabled] {
    opacity: 0.5;
    cursor: wait;
  }
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .form-status {
    margin: 0;
    min-height: 1.4em;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-fg-dim);
    text-align: center;
  }
  .form-status.ok {
    color: var(--color-accent);
  }
  .form-status.err {
    color: #ff6b6b;
  }
</style>
