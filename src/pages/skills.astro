---
import BaseLayout from '@layouts/BaseLayout.astro';
// BOJ 서비스 종료로 BojWidget 비활성화
// import BojWidget from '@components/BojWidget.astro';
import GithubWidget from '@components/GithubWidget.astro';

const skills = [
  {
    icon: '[ C ]',
    name: 'C — Main',
    desc: '주로 사용하는 언어. io/lib 외의 자료구조·알고리즘은 가능하면 직접 구현해보면서 포인터·메모리 레이아웃 같은 저수준 개념을 공부하고 있습니다.',
  },
  {
    icon: '[ C++ ]',
    name: 'C++ — Design Patterns',
    desc: '싱글턴·커맨드·팩토리 같은 설계 패턴을 토이 프로젝트(노트 에디터)에 직접 붙여보면서 OOP 와 자원 관리 감각을 익히고 있습니다.',
  },
  {
    icon: '[ PY / JAVA ]',
    name: 'Python · Java — Sub',
    desc: 'Python 은 자동화·간단한 스크립트·PS 보조용으로, Java 는 OOP 개념 비교와 학과 과제 구현 정도로 사용합니다.',
  },
  {
    icon: '[ ALGORITHM ]',
    name: 'Data Structure & PS',
    desc: '시간/공간 복잡도를 의식하면서 문제 푸는 연습을 꾸준히 이어가는 중입니다.',
  },
  {
    icon: '[ TOOLS ]',
    name: 'Visual Studio · VSCode · Ubuntu',
    desc: '윈도우 쪽은 Visual Studio, 일반 편집은 VSCode, 리눅스는 VirtualBox 위 Ubuntu 를 띄워서 나눠 사용하고 있습니다.',
  },
];

const records = [
  { date: '25.06.13', text: '교내 DoD 알고리즘 대회 우수상' },
  { date: '25.09.09', text: 'U-BDIA 코딩 테스트 참여' },
  { date: '25.09.11', text: 'GDGoC-DEU 멤버 참여' },
  { date: '25.10.11', text: 'ICPC 대회 참여' },
  { date: '26.02.20', text: 'GDGoC-DEU 코어 멤버 참여' },
  // { date: '26.02.21', text: 'solved.ac Gold-V 달성' }, // BOJ 서비스 종료로 비활성화
  { date: '26.04.13', text: 'KIT 바이브코딩 공모전 참여' },
];
---

<BaseLayout
  title="Skills"
  description="std::N 이 다루는 기술과 지금까지 참여한 활동 기록."
>
  <section class="skills-hero">
    <h1 class="h1">Skills &amp; Experience</h1>
    <p class="section-sub">기술 및 역량</p>
  </section>

  <section class="container">
    <div class="skills-section">
      <h2 class="section-h1">SKILLS 기술</h2>
      <div class="skills-stack">
        {skills.map((s) => (
          <article class="skill-card">
            <div class="skill-icon">{s.icon}</div>
            <h3 class="skill-name">{s.name}</h3>
            <p class="skill-desc">{s.desc}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="records-section">
      <h2 class="section-h1">RECORDS 활동</h2>
      <ol class="records">
        {records.map((r) => (
          <li class="record">
            <time class="port-date" datetime={`20${r.date.replace(/\./g, '-')}`}>{r.date}</time>
            <div class="port-inner">{r.text}</div>
          </li>
        ))}
      </ol>
    </div>

    {/* <BojWidget /> — BOJ 서비스 종료로 비활성화 */}
    <GithubWidget />
  </section>
</BaseLayout>

<style>
  .skills-hero {
    text-align: center;
    padding: 40px 20px 0;
  }
  .skills-hero .h1 {
    display: inline-block;
  }
  .section-sub {
    margin-top: 10px;
    font-family: var(--font-mono);
    color: var(--color-fg-dim);
    letter-spacing: 3px;
  }
  .skills-section,
  .records-section {
    margin-top: 60px;
  }
  .skills-stack {
    display: flex;
    flex-direction: column;
    gap: 30px;
    margin-top: 30px;
  }
  .skills-stack .skill-card {
    margin-top: 0;
  }
  .records-section .records {
    margin-top: 30px;
  }
</style>
