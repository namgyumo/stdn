---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatShortDate } from '@lib/format';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);
const staticSlugs = posts.map((p) => p.id);
---

<BaseLayout
  title={undefined}
  description="저수준을 공부하고 직접 구현하는 걸 좋아하는 동의대 컴소공 25학번 남규모의 포트폴리오·블로그."
>
  <section class="home-hero">
    <p class="typing">A Junior Developer Grounded in Basics</p>
    <h1 class="h1">기본이 탄탄한 주니어 개발자.</h1>
    <p class="h2">
      기본에 충실하면서도, 코드가 실제로 어떻게 동작하는지를 이해하려는 개발자가 되고 싶습니다.
    </p>

    <div class="home-cta">
      <a href="/about" class="btntext">
        <div class="box"><strong>저에 대해 더 알아보세요</strong></div>
      </a>
      <a href="/contact" class="btntext">
        <div class="contact-box"><strong>저에게 연락하기</strong></div>
      </a>
    </div>

    <div class="sub-pro">
      <h2 class="h1 hh1">Hi, Welcome to std::N</h2>
      <p class="sub-inner">
        주력 언어는 C 이고, io/lib 외의 자료구조는 가능한 한 직접 구현해보며 감각을 쌓고 있습니다.<br />
        C++ 로는 GoF 설계 패턴을 실제 프로젝트(노트 에디터)에 붙여보는 중입니다.<br />
        장기적으로는 시스템 엔지니어로 자리 잡는 것을 목표로 합니다.
      </p>
    </div>
  </section>

  <section class="home-posts container container-narrow" id="home-posts" style={posts.length === 0 ? 'display:none' : ''}>
    <h2 class="section-h1">Recent Posts</h2>
    <ul class="post-list" id="home-post-list" data-published={posts.map((p) => p.data.publishedAt.toISOString()).join(',')}>
      {posts.map((p) => (
        <li data-slug={p.id} data-published={p.data.publishedAt.toISOString()}>
          <a class="post-item" href={`/blog/${p.id}`}>
            <span class="post-date">{formatShortDate(p.data.publishedAt)}</span>
            <div>
              <h3 class="post-title">{p.data.title}</h3>
              {p.data.tags && p.data.tags.length > 0 && (
                <div class="post-tags">
                  {p.data.tags.slice(0, 3).map((t: string) => <span class="tag">#{t}</span>)}
                </div>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
    <p style="text-align:center; margin-top: 24px;">
      <a href="/blog" class="btntext">→ 모든 글 보기</a>
    </p>
  </section>

  <script is:inline define:vars={{ staticSlugs }}>
    (async () => {
      try {
        const r = await fetch('/api/posts', { credentials: 'same-origin' });
        if (!r.ok) return;
        const data = await r.json();
        if (!data?.ok || !Array.isArray(data.posts)) return;

        const staticSet = new Set(staticSlugs);
        const d1New = data.posts.filter((p) => !staticSet.has(p.slug));
        if (d1New.length === 0) return;

        const list = document.getElementById('home-post-list');
        const section = document.getElementById('home-posts');
        if (!list) return;

        const fmt = (iso) => {
          const d = new Date(iso);
          return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
        };
        const esc = (s) => s.replace(/[&<>"']/g, (c) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));

        for (const p of d1New) {
          const li = document.createElement('li');
          li.dataset.slug = p.slug;
          li.dataset.published = p.publishedAt;
          li.innerHTML = `
            <a class="post-item" href="/blog/${encodeURIComponent(p.slug)}">
              <span class="post-date">${fmt(p.publishedAt)}</span>
              <div>
                <h3 class="post-title">${esc(p.title)}</h3>
                ${(p.tags && p.tags.length) ? `<div class="post-tags">${p.tags.slice(0,3).map((t) => `<span class="tag">#${esc(t)}</span>`).join('')}</div>` : ''}
              </div>
            </a>
          `;
          list.appendChild(li);
        }

        // 최신 4개만 노출 (날짜 내림차순)
        const items = [...list.querySelectorAll('li')];
        items.sort((a, b) => (b.dataset.published ?? '').localeCompare(a.dataset.published ?? ''));
        list.innerHTML = '';
        items.slice(0, 4).forEach((el) => list.appendChild(el));

        if (section) section.style.display = '';
      } catch {}
    })();
  </script>
</BaseLayout>

<style>
  .home-hero {
    text-align: center;
    padding: 0 20px;
    max-width: var(--container);
    margin: 0 auto;
  }
  .home-hero .h1 {
    display: inline-block;
    margin-top: 30px;
  }
  .home-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-top: 100px;
  }
  .home-posts {
    margin-top: 140px;
  }
  .home-posts h2 {
    text-align: center;
    display: block;
  }
</style>
