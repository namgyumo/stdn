---
// /api/views/:slug 호출해서 조회수 표시 + 첫 진입 시 1회 증가.
// sessionStorage 로 동일 글 중복 카운트 억제.
interface Props {
  slug: string;
}
const { slug } = Astro.props;
---

<span class="view-count" data-slug={slug} aria-live="polite">— views</span>

<script>
  function init() {
    const el = document.querySelector<HTMLSpanElement>('.view-count');
    if (!el) return;
    const slug = el.dataset.slug;
    if (!slug) return;

    const encoded = encodeURIComponent(slug);
    const sessionKey = `viewed:${slug}`;
    const already = sessionStorage.getItem(sessionKey);

    const render = (n: number) => {
      el.textContent = `${n.toLocaleString()} views`;
    };

    const fetchOnly = async () => {
      try {
        const r = await fetch(`/api/views/${encoded}`, { credentials: 'same-origin' });
        if (!r.ok) return;
        const j = await r.json();
        if (j?.ok && typeof j.count === 'number') render(j.count);
      } catch {}
    };

    const incr = async () => {
      try {
        const r = await fetch(`/api/views/${encoded}`, {
          method: 'POST',
          credentials: 'same-origin',
        });
        if (!r.ok) return;
        const j = await r.json();
        if (j?.ok && typeof j.count === 'number') {
          render(j.count);
          sessionStorage.setItem(sessionKey, '1');
        }
      } catch {}
    };

    if (already) {
      fetchOnly();
    } else {
      incr();
    }
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>

<style>
  .view-count {
    font-variant-numeric: tabular-nums;
  }
</style>
